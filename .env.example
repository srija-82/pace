# Cloud SQL Postgres connection string
# For local dev: postgresql://user:password@localhost:5432/pace
# For Cloud Run + Cloud SQL: use the Cloud SQL Auth Proxy / unix socket connection string,
# e.g. postgresql://user:password@localhost/pace?host=/cloudsql/PROJECT:REGION:INSTANCE
DATABASE_URL=

# NextAuth
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Gemini (Google AI Studio)
GEMINI_API_KEY=
